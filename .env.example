# Site
NEXT_PUBLIC_SITE_URL=https://openclaw.ca
NEXT_PUBLIC_SITE_NAME="OpenClaw Consulting"

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Cloudflare Turnstile (anti-spam)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Email (Resend)
RESEND_API_KEY=re_your_api_key
NOTIFICATION_EMAIL=hello@openclaw.ca
FROM_EMAIL=portal@openclaw.ca

# CRM Webhook (optional)
CRM_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/...
CRM_WEBHOOK_SECRET=your_webhook_secret

# Rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
